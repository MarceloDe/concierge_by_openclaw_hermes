FROM python:3.12-slim AS runner

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    WEFELLA_NODE_RUNTIME_URL=http://node-runtime:4173 \
    WEFELLA_AUTH_MODE=local \
    WEFELLA_ENABLE_LOCAL_AUTH=1 \
    WEFELLA_TASK_REGISTRY_PATH=/app/data/tasks.json \
    WEFELLA_UPLOAD_STORE_PATH=/app/data/uploads

WORKDIR /app

RUN groupadd --system app && useradd --system --gid app --home /app app
COPY project/requirements.txt ./project/requirements.txt
RUN pip install --no-cache-dir -r project/requirements.txt
COPY project ./project
RUN mkdir -p /app/data && chown -R app:app /app

USER app
EXPOSE 8000

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=8 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/api/v1/health', timeout=5).read()"

CMD ["python", "-m", "uvicorn", "project.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
