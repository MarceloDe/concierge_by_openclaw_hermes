# Local secrets only. Do not commit real values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Optional. Defaults to the official OpenAI API and ignores unrelated local OPENAI_BASE_URL overrides.
BRAINSTY_OPENAI_BASE_URL=https://api.openai.com/v1

# Phase 5 product memory: real Zep Graphiti runtime, separate from Cortex.
BRAINSTY_PRODUCT_MEMORY_ADAPTER=graphiti
GRAPHITI_BACKEND=falkordb
GRAPHITI_GROUP_ID=brainstyworkers_local
GRAPHITI_LLM_MODEL=gpt-4.1-mini
GRAPHITI_SMALL_MODEL=gpt-4.1-nano
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small
GRAPHITI_STORE_RAW_EPISODES=0
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# Phase 9A-9H complementary Wefella FastAPI facade.
# The facade is API-first and delegates to the existing Node/LangGraph/OpenClaw runtime.
WEFELLA_NODE_RUNTIME_URL=http://127.0.0.1:4173
WEFELLA_JWT_SECRET=dev-only-change-me
WEFELLA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:4173,http://127.0.0.1:8000
WEFELLA_ENABLE_LOCAL_AUTH=1

# Provider auth mode for deployed/API-facing environments.
# In provider mode, configure issuer/audience and disable local-session minting.
WEFELLA_AUTH_MODE=local
WEFELLA_JWT_ISSUER=
WEFELLA_JWT_AUDIENCE=
# RBAC: research/operator facade routes require JWT role `operator` or `admin`.
# Supported role claims: roles, role, groups, permissions, scope, scp.
# Local-session tokens minted by /api/auth/local-session default to user role only.

# Facade hardening and deployment smoke checks.
WEFELLA_RATE_LIMIT_PER_MINUTE=120
WEFELLA_RATE_LIMIT_DISABLED=0
WEFELLA_TASK_REGISTRY_PATH=
WEFELLA_ENFORCE_SOURCE_GROUNDING=0
WEFELLA_FACADE_URL=http://127.0.0.1:8000

# Phase 10G operator research execution.
# deterministic_fetch performs approved-source HTTP(S) fetch plus local extraction.
# mock_worker is an explicit untrusted fallback for demos when real workers/sites are unavailable.
# openclaw and hermes are real adaptive worker adapters; they remain disabled unless explicitly enabled.
BRAINSTY_RESEARCH_WORKER_MODE=deterministic_fetch
BRAINSTY_RESEARCH_ARTIFACT_DIR=data/research-artifacts
BRAINSTY_RESEARCH_FETCH_MAX_BYTES=1048576
BRAINSTY_RESEARCH_OPENCLAW_ENABLED=0
BRAINSTY_RESEARCH_HERMES_ENABLED=0
BRAINSTY_RESEARCH_WORKER_TIMEOUT_SECONDS=180
BRAINSTY_RESEARCH_OPENCLAW_AGENT_ID=brainstyworkers-insurance-browser
BRAINSTY_HERMES_BINARY=hermes
BRAINSTY_RESEARCH_HERMES_MODEL=
BRAINSTY_RESEARCH_HERMES_PROVIDER=
BRAINSTY_RESEARCH_HERMES_TOOLSETS=
BRAINSTY_RESEARCH_EMBEDDING_PROVIDER=local_tfidf
BRAINSTY_RESEARCH_EMBEDDING_DIMENSIONS=64
BRAINSTY_RESEARCH_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
BRAINSTY_RESEARCH_OPENAI_EMBEDDING_DIMENSIONS=1536

# Phase 10A local document upload and extraction harness.
WEFELLA_UPLOAD_STORE_PATH=data/wefella-uploads
WEFELLA_UPLOAD_MAX_BYTES=5242880

# Optional observability hooks. JSONL export stores safe task/status metadata only.
WEFELLA_OBSERVABILITY_EVENTS_PATH=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=brainstyworkers-local
LANGSMITH_API_KEY=
