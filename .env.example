# Local secrets only. Do not commit real values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Optional. Defaults to the official OpenAI API and ignores unrelated local OPENAI_BASE_URL overrides.
BRAINSTY_OPENAI_BASE_URL=https://api.openai.com/v1

# Phase 5 product memory: real Zep Graphiti runtime, separate from Cortex.
BRAINSTY_PRODUCT_MEMORY_ADAPTER=graphiti
GRAPHITI_BACKEND=falkordb
GRAPHITI_GROUP_ID=brainstyworkers_local
GRAPHITI_LLM_MODEL=gpt-4.1-mini
GRAPHITI_SMALL_MODEL=gpt-4.1-nano
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small
GRAPHITI_STORE_RAW_EPISODES=0
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# Phase 9A complementary Wefella FastAPI facade.
# The facade is API-first and delegates to the existing Node/LangGraph/OpenClaw runtime.
WEFELLA_NODE_RUNTIME_URL=http://127.0.0.1:4173
WEFELLA_JWT_SECRET=dev-only-change-me
WEFELLA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:4173,http://127.0.0.1:8000
WEFELLA_ENABLE_LOCAL_AUTH=1
