# Copy this template outside Git before running hosted-provider visual/OCR replay proof.
# Do not commit the copied file. The proof manifest must stay outside the repo and
# must contain only opaque refs, booleans, and redacted status fields.

WEFELLA_BROWSER_SANDBOX_PROVIDER=hosted_remote
WEFELLA_BROWSER_SANDBOX_PROVIDER_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_CONFIG_FILE=/run/secrets/browser-sandbox-provider.runtime.json
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_FILE=project/deployment/browser-sandbox-provider.selection.example.json
WEFELLA_BROWSER_SANDBOX_SELECTED_PROVIDER=custom_webrtc
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_PREFLIGHT_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_VERIFICATION_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_WEBRTC_SIGNALING_READY=1

# Set to 1 only after a real operator-captured dashboard/mobile live-block proof
# manifest is available outside Git and contains no raw screenshots, OCR text,
# endpoint URLs, tokens, SDP, ICE candidates, credentials, or portal/member text.
WEFELLA_BROWSER_SANDBOX_PROVIDER_VISUAL_OCR_REPLAY_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_VISUAL_OCR_PROOF_FILE=/run/secrets/browser-sandbox-provider-visual-ocr-proof.json

# These names must match endpointRef/auth.tokenRef in the private runtime JSON.
WEFELLA_BROWSER_SANDBOX_ENDPOINT_URL=https://provider.example.invalid/api
WEFELLA_BROWSER_SANDBOX_API_TOKEN=replace-with-secret-manager-value

# Leave hosted readiness disabled until all private live, WebRTC, and visual/OCR
# proof gates pass against the real provider.
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_VERIFIED=0
