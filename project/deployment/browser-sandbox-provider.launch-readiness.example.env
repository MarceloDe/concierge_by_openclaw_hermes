# Copy this template outside Git before running hosted-provider launch readiness.
# Do not commit the copied file. Provider endpoints, tokens, runtime JSON, and
# visual/OCR proof manifests must stay in the selected secret manager or an
# operator-controlled private path.

WEFELLA_BROWSER_SANDBOX_PROVIDER=hosted_remote
WEFELLA_BROWSER_SANDBOX_PROVIDER_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_CONFIG_FILE=/run/secrets/browser-sandbox-provider.runtime.json
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_FILE=project/deployment/browser-sandbox-provider.selection.example.json
WEFELLA_BROWSER_SANDBOX_SELECTED_PROVIDER=custom_webrtc

# Gate each step only after its private proof has passed.
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_PREFLIGHT_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_PREFLIGHT_PROBE=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_VERIFICATION_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_WEBRTC_SIGNALING_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_VISUAL_OCR_REPLAY_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_VISUAL_OCR_PROOF_FILE=/run/secrets/browser-sandbox-provider-visual-ocr-proof.json

# These names must match endpointRef/auth.tokenRef in the private runtime JSON.
WEFELLA_BROWSER_SANDBOX_ENDPOINT_URL=https://provider.example.invalid/api
WEFELLA_BROWSER_SANDBOX_API_TOKEN=replace-with-secret-manager-value

# Phase 26 readiness is an operator review gate. Set it only after the private
# proof chain above is green and reviewed.
WEFELLA_BROWSER_SANDBOX_PROVIDER_LAUNCH_READINESS_READY=0

# Final hosted readiness remains disabled until the real provider is live
# verified and private runtime JSON sets adapter.providerLiveConnected=true.
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_VERIFIED=0
