# Copy this template outside Git before running the private hosted-provider launch execution.
# Do not commit the copied file, provider endpoint, token, runtime config, screenshots,
# OCR text, SDP, ICE candidates, visual proof manifests, or provider artifacts.

# Private runtime JSON outside Git. It must use adapter.mode=hosted_provider.
WEFELLA_BROWSER_SANDBOX_PROVIDER_CONFIG_FILE=/run/secrets/browser-sandbox-provider.runtime.json

# Private provider endpoint and token are resolved by refs inside the runtime JSON.
# These sample names match project/deployment/browser-sandbox-provider.hosted-provider.example.json.
WEFELLA_BROWSER_SANDBOX_ENDPOINT_URL=
WEFELLA_BROWSER_SANDBOX_API_TOKEN=

# Selection and proof-chain gates. Set each to 1 only after the corresponding private proof passes.
WEFELLA_BROWSER_SANDBOX_PROVIDER=hosted_remote
WEFELLA_BROWSER_SANDBOX_PROVIDER_READY=1
WEFELLA_BROWSER_SANDBOX_SELECTED_PROVIDER=
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_PREFLIGHT_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_VERIFICATION_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_WEBRTC_SIGNALING_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_VISUAL_OCR_REPLAY_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_VISUAL_OCR_PROOF_FILE=/run/secrets/browser-sandbox-provider.visual-ocr-proof.json
WEFELLA_BROWSER_SANDBOX_PROVIDER_LAUNCH_READINESS_READY=0

# Final private execution gates. Leave disabled until the operator reviews the
# real provider run: session, stream, screenshot/OCR, takeover, approved input,
# offsite fail-closed behavior, teardown, dashboard/mobile proof, and no leaks.
WEFELLA_BROWSER_SANDBOX_PROVIDER_PRIVATE_LAUNCH_EXECUTION_READY=0
WEFELLA_BROWSER_SANDBOX_PROVIDER_FINAL_HUMAN_REVIEWED=0

# Final hosted readiness switch. Set to 1 only together with private runtime JSON
# adapter.providerLiveConnected=true after real provider proof and human review.
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_VERIFIED=0
