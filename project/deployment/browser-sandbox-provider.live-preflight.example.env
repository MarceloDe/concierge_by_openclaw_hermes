# Copy these values into a private, ignored environment file before a real provider run.
# Do not commit raw provider endpoints, tokens, screenshots, OCR text, or frame data.

WEFELLA_BROWSER_SANDBOX_PROVIDER=hosted_remote
WEFELLA_BROWSER_SANDBOX_PROVIDER_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_CONFIG_FILE=project/deployment/browser-sandbox-provider.<provider>.runtime.json
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_FILE=project/deployment/browser-sandbox-provider.selection.example.json
WEFELLA_BROWSER_SANDBOX_SELECTED_PROVIDER=custom_webrtc
WEFELLA_BROWSER_SANDBOX_PROVIDER_SELECTION_READY=1
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_PREFLIGHT_READY=1

# Optional: only set this to 1 when the provider health endpoint is ready for a live network probe.
WEFELLA_BROWSER_SANDBOX_PROVIDER_LIVE_PREFLIGHT_PROBE=0

# These values are referenced by the private runtime JSON through env: refs.
WEFELLA_BROWSER_SANDBOX_ENDPOINT_URL=
WEFELLA_BROWSER_SANDBOX_API_TOKEN=
