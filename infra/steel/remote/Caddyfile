{
	servers {
		trusted_proxies static private_ranges
	}
}

STEEL_REMOTE_HOST:443 {
	@allow_backend remote_ip {$STEEL_BACKEND_EGRESS_CIDRS}
	@blocked_backend not remote_ip {$STEEL_BACKEND_EGRESS_CIDRS}
	respond @blocked_backend 403

	request_header -X-Forwarded-For
	request_header -X-Real-IP
	header {
		-Server
		-X-Powered-By
	}

	@health {
		method GET
		path /v1/health
	}
	@create_session {
		method POST
		path /v1/sessions
	}
	@session_screenshot {
		method POST
		path_regexp session_screenshot ^/v1/sessions/.+/screenshot$
	}
	@session_release {
		method POST
		path_regexp session_release ^/v1/sessions/.+/release$
	}
	@session_viewer {
		method GET
		path_regexp session_viewer ^/v1/sessions/.+/viewer.*$
	}

	reverse_proxy @health 127.0.0.1:3000
	reverse_proxy @create_session 127.0.0.1:3000
	reverse_proxy @session_screenshot 127.0.0.1:3000
	reverse_proxy @session_release 127.0.0.1:3000
	reverse_proxy @session_viewer 127.0.0.1:3000

	respond 404
}
